#: python-fu-bgremove.py
msgid "Saving image for processing..."
msgstr "Bild für Verarbeitung speichern..."

#: python-fu-bgremove.py
msgid "Running background removal (this may take time)..."
msgstr "Hintergrundentfernung läuft (dies kann dauern)..."

#: python-fu-bgremove.py
msgid "Background remover failed. Ensure 'backgroundremover' is installed and working."
msgstr "Hintergrundentfernung fehlgeschlagen. Stellen Sie sicher, dass 'backgroundremover' installiert ist und funktioniert."

#: python-fu-bgremove.py
msgid "Background remover executed successfully but failed to create the output file."
msgstr "Hintergrundentfernung erfolgreich ausgeführt, aber die Ausgabedatei wurde nicht erstellt."

#: python-fu-bgremove.py
msgid "Loading processed image..."
msgstr "Verarbeitetes Bild laden..."

#: python-fu-bgremove.py
msgid "Failed to load the processed image file."
msgstr "Fehler beim Laden der verarbeiteten Bilddatei."

#: python-fu-bgremove.py
msgid "Background Removed Layer"
msgstr "Ebene ohne Hintergrund"

#: python-fu-bgremove.py
msgid "Transferring layer data..."
msgstr "Übertrage Ebenendaten..."

#: python-fu-bgremove.py
msgid "Background Removed"
msgstr "Hintergrund entfernt"

#: python-fu-bgremove.py
msgid "An unexpected error occurred: %s"
msgstr "Ein unerwarteter Fehler ist aufgetreten: %s"

#: python-fu-bgremove.py
msgid "Remove Background"
msgstr "Hintergrund entfernen"

#: python-fu-bgremove.py
msgid "Uses the external 'backgroundremover' tool to automatically remove the background from the active image or layer."
msgstr "Verwendet das externe Tool 'backgroundremover', um automatisch den Hintergrund aus dem aktiven Bild oder der aktiven Ebene zu entfernen."

#: python-fu-bgremove.py
msgid "Remove _Background..."
msgstr "_Hintergrund entfernen..."
