#: python-fu-bgremove.py
msgid "Saving image for processing..."
msgstr "Enregistrement de l'image pour traitement..."

#: python-fu-bgremove.py
msgid "Running background removal (this may take time)..."
msgstr "Suppression de l'arrière-plan (cela peut prendre du temps)..."

#: python-fu-bgremove.py
msgid "Background remover failed. Ensure 'backgroundremover' is installed and working."
msgstr "La suppression d'arrière-plan a échoué. Assurez-vous que 'backgroundremover' est installé et fonctionne."

#: python-fu-bgremove.py
msgid "Background remover executed successfully but failed to create the output file."
msgstr "La suppression d'arrière-plan a réussi mais n'a pas créé le fichier de sortie."

#: python-fu-bgremove.py
msgid "Loading processed image..."
msgstr "Chargement de l'image traitée..."

#: python-fu-bgremove.py
msgid "Failed to load the processed image file."
msgstr "Échec du chargement du fichier image traité."

#: python-fu-bgremove.py
msgid "Background Removed Layer"
msgstr "Calque sans fond"

#: python-fu-bgremove.py
msgid "Transferring layer data..."
msgstr "Transfert des données du calque..."

#: python-fu-bgremove.py
msgid "Background Removed"
msgstr "Arrière-plan supprimé"

#: python-fu-bgremove.py
msgid "An unexpected error occurred: %s"
msgstr "Une erreur inattendue s'est produite : %s"

#: python-fu-bgremove.py
msgid "Remove Background"
msgstr "Supprimer l'arrière-plan"

#: python-fu-bgremove.py
msgid "Uses the external 'backgroundremover' tool to automatically remove the background from the active image or layer."
msgstr "Utilise l'outil externe 'backgroundremover' pour supprimer automatiquement l'arrière-plan de l'image ou du calque actif."

#: python-fu-bgremove.py
msgid "Remove _Background..."
msgstr "Supprimer l'_arrière-plan..."
