#: python-fu-aiedit.py
msgid "Saving image for processing..."
msgstr "正在保存图像以进行处理..."

#: python-fu-aiedit.py
msgid "Running AI edit (this may take time)..."
msgstr "正在AI编辑（这可能需要一些时间）..."

#: python-fu-aiedit.py
msgid "AI edit failed. Ensure 'sd-cli' is installed and working."
msgstr "AI编辑失败。请确保已安装 'sd-cli' 且运行正常。"

#: python-fu-aiedit.py
msgid "AI edit executed but failed to create the output file."
msgstr "AI编辑已执行，但未能创建输出文件。"

#: python-fu-aiedit.py
msgid "Loading processed image..."
msgstr "正在加载处理后的图像..."

#: python-fu-aiedit.py
msgid "Failed to load the processed image file."
msgstr "加载处理后的图像文件失败。"

#: python-fu-aiedit.py
msgid "AI Edit Layer"
msgstr "AI编辑图层"

#: python-fu-aiedit.py
msgid "Transferring layer data..."
msgstr "正在传输图层数据..."

#: python-fu-aiedit.py
msgid "AI Edited"
msgstr "AI已编辑"

#: python-fu-aiedit.py
msgid "An unexpected error occurred: %s"
msgstr "发生意外错误：%s"

#: python-fu-aiedit.py
msgid "AI Edit"
msgstr "AI编辑"

#: python-fu-aiedit.py
msgid "Uses sd-cli with a diffusion model and vision LLM to edit the active image or layer based on a text prompt."
msgstr "使用sd-cli结合扩散模型和视觉LLM，根据文本提示编辑活动图像或图层。"

#: python-fu-aiedit.py
msgid "AI _Edit..."
msgstr "AI_编辑..."

#: python-fu-aiedit.py
msgid "Diffusion _Model"
msgstr "扩散_模型"

#: python-fu-aiedit.py
msgid "Path to the diffusion model GGUF file"
msgstr "扩散模型GGUF文件的路径"

#: python-fu-aiedit.py
msgid "_LLM"
msgstr "_LLM"

#: python-fu-aiedit.py
msgid "Path to the LLM GGUF file"
msgstr "LLM的GGUF文件路径"

#: python-fu-aiedit.py
msgid "LLM _Vision"
msgstr "LLM_视觉"

#: python-fu-aiedit.py
msgid "Path to the LLM vision model mmproj file"
msgstr "LLM视觉模型mmproj文件的路径"

#: python-fu-aiedit.py
msgid "_VAE"
msgstr "_VAE"

#: python-fu-aiedit.py
msgid "Path to the VAE model file"
msgstr "VAE模型文件的路径"

#: python-fu-aiedit.py
msgid "_Prompt"
msgstr "_提示"

#: python-fu-aiedit.py
msgid "Describe the edit you want to apply to the image"
msgstr "描述您想要应用到图像的编辑内容"
