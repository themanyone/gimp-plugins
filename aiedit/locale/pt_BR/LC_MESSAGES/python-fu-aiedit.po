#: python-fu-aiedit.py
msgid "Saving image for processing..."
msgstr "Salvando imagem para processamento..."

#: python-fu-aiedit.py
msgid "Running AI edit (this may take time)..."
msgstr "Editando com IA (isso pode levar tempo)..."

#: python-fu-aiedit.py
msgid "AI edit failed. Ensure 'sd-cli' is installed and working."
msgstr "Edição IA falhou. Certifique-se de que 'sd-cli' está instalado e funcionando."

#: python-fu-aiedit.py
msgid "AI edit executed but failed to create the output file."
msgstr "Edição IA executada, mas não criou o arquivo de saída."

#: python-fu-aiedit.py
msgid "Loading processed image..."
msgstr "Carregando imagem processada..."

#: python-fu-aiedit.py
msgid "Failed to load the processed image file."
msgstr "Falha ao carregar o arquivo de imagem processada."

#: python-fu-aiedit.py
msgid "AI Edit Layer"
msgstr "Camada de edição IA"

#: python-fu-aiedit.py
msgid "Transferring layer data..."
msgstr "Transferindo dados da camada..."

#: python-fu-aiedit.py
msgid "AI Edited"
msgstr "Editada por IA"

#: python-fu-aiedit.py
msgid "An unexpected error occurred: %s"
msgstr "Ocorreu um erro inesperado: %s"

#: python-fu-aiedit.py
msgid "AI Edit"
msgstr "Edição IA"

#: python-fu-aiedit.py
msgid "Uses sd-cli with a diffusion model and vision LLM to edit the active image or layer based on a text prompt."
msgstr "Usa sd-cli com um modelo de difusão e LLM de visão para editar a imagem ou camada ativa com base em um prompt de texto."

#: python-fu-aiedit.py
msgid "AI _Edit..."
msgstr "Edição _IA..."

#: python-fu-aiedit.py
msgid "Diffusion _Model"
msgstr "Modelo de _Difusão"

#: python-fu-aiedit.py
msgid "Path to the diffusion model GGUF file"
msgstr "Caminho para o arquivo GGUF do modelo de difusão"

#: python-fu-aiedit.py
msgid "_LLM"
msgstr "_LLM"

#: python-fu-aiedit.py
msgid "Path to the LLM GGUF file"
msgstr "Caminho para o arquivo GGUF do LLM"

#: python-fu-aiedit.py
msgid "LLM _Vision"
msgstr "_Visão do LLM"

#: python-fu-aiedit.py
msgid "Path to the LLM vision model mmproj file"
msgstr "Caminho para o arquivo mmproj do modelo de visão LLM"

#: python-fu-aiedit.py
msgid "_VAE"
msgstr "_VAE"

#: python-fu-aiedit.py
msgid "Path to the VAE model file"
msgstr "Caminho para o arquivo do modelo VAE"

#: python-fu-aiedit.py
msgid "_Prompt"
msgstr "_Prompt"

#: python-fu-aiedit.py
msgid "Describe the edit you want to apply to the image"
msgstr "Descreva a edição que deseja aplicar à imagem"
