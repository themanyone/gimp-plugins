#: python-fu-upscale.py
msgid "Saving image for processing..."
msgstr "Guardando imagen para procesar..."

#: python-fu-upscale.py
msgid "Running AI upscaling (this may take time)..."
msgstr "Escalando con IA (esto puede tomar tiempo)..."

#: python-fu-upscale.py
msgid "Loading upscaled image..."
msgstr "Cargando imagen escalada..."

#: python-fu-upscale.py
msgid "Upscaling failed to produce the output file."
msgstr "El escalado falló al producir el archivo de salida."

#: python-fu-upscale.py
msgid "Failed to load the upscaled image file."
msgstr "Error al cargar el archivo de imagen escalada."

#: python-fu-upscale.py
msgid "Upscaled Layer"
msgstr "Capa escalada"

#: python-fu-upscale.py
msgid "Transferring layer data..."
msgstr "Transfiriendo datos de capa..."

#: python-fu-upscale.py
msgid "Upscaled"
msgstr "Escalada"

#: python-fu-upscale.py
msgid "An unexpected error occurred: %s"
msgstr "Ocurrió un error inesperado: %s"

#: python-fu-upscale.py
msgid "Upscale Image"
msgstr "Escalar Imagen"

#: python-fu-upscale.py
msgid "Uses AI to upscale the active image or layer by 4x. Supports multiple backends: Spandrel (UltraSharp, DAT2) and Diffusers (LDM)."
msgstr "Utiliza IA para escalar la imagen o capa activa 4x. Soporta múltiples motores: Spandrel (UltraSharp, DAT2) y Diffusers (LDM)."

#: python-fu-upscale.py
msgid "_Upscale..."
msgstr "_Escalar..."

#: python-fu-upscale.py
msgid "_Model"
msgstr "_Modelo"

#: python-fu-upscale.py
msgid "Upscaling model to use"
msgstr "Modelo de escalado a usar"

#: python-fu-upscale.py
msgid "Unknown model '%s'. Add it to MODEL_CONFIGS."
msgstr "Modelo '%s' desconocido. Agréguelo a MODEL_CONFIGS."

#: python-fu-upscale.py
msgid "Unsupported model type '%s' in MODEL_CONFIGS."
msgstr "Tipo de modelo '%s' no soportado en MODEL_CONFIGS."
