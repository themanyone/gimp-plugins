#: python-fu-upscale.py
msgid "Saving image for processing..."
msgstr "Bild für Verarbeitung speichern..."

#: python-fu-upscale.py
msgid "Running AI upscaling (this may take time)..."
msgstr "KI-Skalierung läuft (dies kann dauern)..."

#: python-fu-upscale.py
msgid "Loading upscaled image..."
msgstr "Skaliertes Bild laden..."

#: python-fu-upscale.py
msgid "Upscaling failed to produce the output file."
msgstr "Skalierung konnte die Ausgabedatei nicht erstellen."

#: python-fu-upscale.py
msgid "Failed to load the upscaled image file."
msgstr "Fehler beim Laden der skalierten Bilddatei."

#: python-fu-upscale.py
msgid "Upscaled Layer"
msgstr "Skalierte Ebene"

#: python-fu-upscale.py
msgid "Transferring layer data..."
msgstr "Übertrage Ebenendaten..."

#: python-fu-upscale.py
msgid "Upscaled"
msgstr "Skaliert"

#: python-fu-upscale.py
msgid "An unexpected error occurred: %s"
msgstr "Ein unerwarteter Fehler ist aufgetreten: %s"

#: python-fu-upscale.py
msgid "Upscale Image"
msgstr "Bild skalieren"

#: python-fu-upscale.py
msgid "Uses AI to upscale the active image or layer by 4x. Supports multiple backends: Spandrel (UltraSharp, DAT2) and Diffusers (LDM)."
msgstr "Verwendet KI, um das aktive Bild oder die aktive Ebene 4x zu skalieren. Unterstützt mehrere Backends: Spandrel (UltraSharp, DAT2) und Diffusers (LDM)."

#: python-fu-upscale.py
msgid "_Upscale..."
msgstr "_Skalieren..."

#: python-fu-upscale.py
msgid "_Model"
msgstr "_Modell"

#: python-fu-upscale.py
msgid "Upscaling model to use"
msgstr "Zu verwendendes Skalierungsmodell"

#: python-fu-upscale.py
msgid "Unknown model '%s'. Add it to MODEL_CONFIGS."
msgstr "Unbekanntes Modell '%s'. Fügen Sie es zu MODEL_CONFIGS hinzu."

#: python-fu-upscale.py
msgid "Unsupported model type '%s' in MODEL_CONFIGS."
msgstr "Nicht unterstützter Modelltyp '%s' in MODEL_CONFIGS."
